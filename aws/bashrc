#!/usr/bin/env bash

source $PREFERENCES_DIR/util/override.sh

#localstack
wrap '' 'AWS_ACCESS_KEY_ID=test AWS_SECRET_ACCESS_KEY=test AWS_DEFAULT_REGION=${DEFAULT_REGION:-$AWS_DEFAULT_REGION} aws --endpoint-url=http://${LOCALSTACK_HOST:-localhost}:4566' awslocal

if command -v aws_completer &> /dev/null; then
    complete -C "$(command -v aws_completer)" aws
fi

function awsLogined {
    ! [ -z ${AWS_PROFILE:+x} ]
}

function parse_date_to_epoch {
    local date_str="$1"
    if [ "$PREFERENCES_OS" == "Darwin" ]; then
        date -j -f "%Y-%m-%dT%H:%M:%SZ" "$date_str" "+%s" 2>/dev/null || \
        date -j -f "%Y-%m-%dT%H:%M:%S%z" "$date_str" "+%s" 2>/dev/null || \
        date -j -f "%Y-%m-%d %H:%M:%S%z" "$date_str" "+%s" 2>/dev/null || \
        date -j "$date_str" "+%s" 2>/dev/null
    else
        date -d "$date_str" "+%s" 2>/dev/null
    fi
}

function PREFERENCES_AWS_PS1 {
    local ret=""
    if awsLogined; then
        local expire_epoch=$(parse_date_to_epoch "$AWS_CREDENTIAL_EXPIRATION")
        if [ -n "$expire_epoch" ]; then
            local second_to_expire=$(( expire_epoch - $(date "+%s") ))
            if [[ $second_to_expire -gt 0 ]]; then
                local hh=$(( second_to_expire / 3600 ))
                local mm=$(( (second_to_expire % 3600) / 60 ))
                local ss=$(( second_to_expire % 60 ))
                local duration
                printf -v duration "%02d:%02d:%02d" $hh $mm $ss
                ret=" {$AWS_PROFILE|$duration|$AWS_ACCOUNT_ID}"
            else
                export AWS_PROFILE=""
            fi
        fi
    fi

    echo "$ret"
}

function awsLogin {
    if [[ $# < 1 ]]; then
        echo "usage: ${FUNCNAME} [profile]"
        return
    fi

    local profile=$1
    aws sso login --profile $profile

    if [[ $? -eq 0 ]]; then
        export AWS_PROFILE=$profile
        eval $(aws configure export-credentials --profile $profile --format env)
    else
        echo "login with $profile failed"
    fi
}


function awsEcrLogin {
    if ! awsLogined; then
        echo "AWS_PROFILE is empty, awsLogin first"
        return
    fi

    local accountID=$(aws sts get-caller-identity --query Account --output text --profile $AWS_PROFILE)
    local addr="${accountID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com"
    echo "login to ecr in ${addr}"
    aws ecr get-login-password --profile $AWS_PROFILE | docker login --username AWS --password-stdin "$addr"

    if [[ $? -eq 0 ]]; then
        export AWS_ACCOUNT_ID=$accountID
    fi
}

function awsEcsBash {
    if ! awsLogined; then
        echo "AWS_PROFILE is empty, awsLogin first"
        return
    fi

    local clusterName='work'
    local containerName='work'
    while [[ $# -gt 0 ]]; do
        case "$1" in
          --cluster)
            clusterName="$2"
            shift 2
            ;;
          --container)
            containerName="$2"
            shift 2
            ;;
          --verbose)
            set -x
            shift
            ;;
          *)
            echo "Unknown option: $1"
            return 1
            ;;
        esac
      done

    local taskArn=$(aws ecs list-tasks --cluster $clusterName --query 'taskArns[0]' --output text)
    if [[ -z "$taskArn" ]] || [[ "$taskArn" == 'None' ]]; then
        echo "TaskArn is empty, start ecs first"
        return
    fi
    aws ecs execute-command --cluster $clusterName --task $taskArn --container $containerName --interactive --command 'bash'
    set +x
}

