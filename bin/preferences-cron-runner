#!/usr/bin/env bash

source "$(dirname "${BASH_SOURCE[0]}")/../util/bootstrap.sh"

# Establish log directory and file
LOG_DIR="$PREFERENCES_DIR/.workspace/cron"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/cron.log"

# Run all submodule cron.sh files and append to log
{
    echo "=========================================="
    echo "⏰ Preferences Cron Triggered: $(date)"
    echo "👤 User: $(whoami) | OS: $PREFERENCES_OS"
    echo "=========================================="
    
    # Discovery and source all submodule cron.sh files
    eachSubFile "$PREFERENCES_DIR" 'source' 'cron.sh'
    
    echo "=========================================="
    echo "✅ Preferences Cron Completed: $(date)"
    echo ""
} >> "$LOG_FILE" 2>&1
